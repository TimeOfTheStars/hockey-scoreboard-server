# Порт HTTP (по умолчанию 8765)
# PORT=8765

# Путь к SQLite (каталог создаётся автоматически)
# DATABASE_PATH=./data/hockey.db

# Секрет подписи JWT (в продакшене задайте длинную случайную строку)
# JWT_SECRET=

# Первый администратор создаётся при пустой БД (один раз)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# Cookie с флагом Secure (1/true за прокси с HTTPS)
# COOKIE_SECURE=true

# Каталог со статикой фронта после `npm run build`
# STATIC_DIR=../dist

# Базовый URL сайта для абсолютных ссылок на логотипы в GET /api/sessions/.../vmix и .../state
# (кириллица в имени файла остаётся в URL как в IRI; пробелы — как %20)
# PUBLIC_BASE_URL=https://scoreboard.example.com

# Запуск (пример):
# uvicorn hockey_server.main:create_app --factory --host 0.0.0.0 --port 8765
